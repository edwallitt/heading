# Heading — environment variables (Phase 0)
# v0 is stateless: no database, no secrets yet. Placeholders only.

# --- apps/server ---
# Port the Hono server listens on (defaults to 3001 if unset).
PORT=

# Anthropic API key for AI dispatch (Phase 2). Server-side only — never exposed
# to the client. Without it, flight.generate falls back to an algorithmic pick.
ANTHROPIC_API_KEY=

# --- apps/web ---
# Base URL the web app uses to reach the tRPC server.
VITE_TRPC_URL=
